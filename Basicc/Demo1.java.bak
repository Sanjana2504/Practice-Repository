class Demo1
{
    public static void main(String[] args)
    {
        System.out.println(10+10);//20
	System.out.println(10+"Hello");//10Hello
	System.out.println("Hello"+"Bye");//HelloBye
	System.out.println(10+10+"Hello");//20Hello
	System.out.println("Hello"+10+10);//Hello1010
	System.out.println('A'+"Hello");//AHello
	System.out.println('A'+'A');//130
	System.out.println('A'+10);//75
    }
}